{
  "manifest_version": 3,
  "name": "Tasy PDF Auto",
  "version": "2.0.0",
  "description": "Otimização visual no Tasy: Troca Suave (Buffer), Prefetch e Debounce em relatórios.",
  "author": "Matteus, Juan e Denes",
  "permissions": ["scripting", "tabs", "webNavigation", "storage"],
  "host_permissions": ["*://*/*"],
  "icons": {
    "512": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["*://*/*"]
    }
  ]
}