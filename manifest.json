{
  "manifest_version": 3,
  "name": "Tasy PDF Auto",
  "version": "2.0.0",
  "description": "Gera PDF automaticamente ao salvar no Tasy HTML5",
  "author": "Matteus, Juan, Denes",
  "permissions": ["scripting", "tabs", "webNavigation", "storage"],
  "host_permissions": ["*://*/*"],
  "icons": {
    "512": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["src/content/contentBridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/pdfService.js",
        "src/injected/uiManager.js",
        "src/injected/httpInterceptor.js",
        "src/injected/core.js"
      ],
      "matches": ["*://*/*"]
    }
  ]
}